#!/usr/bin/env zsh
#
# copilot-proxy - LiteLLM proxy for GitHub Copilot models
#
# Usage: copilot-proxy [--port <number>] [--nightly]
#
# Options:
#   --port <number>  Port to run the proxy on (default: 4000)
#   --nightly        Use LiteLLM nightly from GitHub main
#
# Getting Started
#
# 1. Create a GitHub Personal Access Token with copilot permissions:
#    https://github.com/settings/tokens/new?scopes=copilot&description=LiteLLM%20Copilot%20Proxy
# 2. Store in 1password or macOS Keychain:
#    1Password: op item create --title "litellm-copilot-token"  --vault "abc" --category "API Credential" --field "token=ghu_xxx_your_token"
#    macOS Keychain: security add-generic-password -a "$USER" -s litellm-copilot-token -w "ghu_xxx_your_token"
# 3. Set COPILOT_PROXY_TOKEN_CMD in your shell profile:
#    # 1Password:
#    export COPILOT_PROXY_TOKEN_CMD='op read --account my.1password.com op://private/litellm-copilot-token/token'
#    # macOS Keychain:
#    export COPILOT_PROXY_TOKEN_CMD='security find-generic-password -a "$USER" -s litellm-copilot-token -w'
# 4. Install uv:
#    brew install uv
# 5. Update your shell profile and set ANTHROPIC_BASE_URL:
#    export ANTHROPIC_BASE_URL="http://localhost:4000"
#

# Default port
PORT=4000
USE_NIGHTLY=false

# Parse command line arguments
while [[ $# -gt 0 ]]; do
  case $1 in
    --port)
      PORT="$2"
      shift 2
      ;;
    --nightly)
      USE_NIGHTLY=true
      shift
      ;;
    *)
      echo "Unknown option: $1"
      echo "Usage: copilot-proxy [--port <number>] [--nightly]"
      exit 1
      ;;
  esac
done

# Check for COPILOT_PROXY_TOKEN_CMD
if [[ -z "$COPILOT_PROXY_TOKEN_CMD" ]]; then
  COPILOT_PROXY_TOKEN_CMD='op read --account my.1password.com op://private/litellm-copilot-token/token'
fi

# Get token using the configured command
TOKEN=$(eval "$COPILOT_PROXY_TOKEN_CMD") || exit 1
export GITHUB_TOKEN="$TOKEN"

CONFIG_FILE="$HOME/.dotfiles/.litellm-config.yaml"

# Check for uv
if ! command -v uvx &> /dev/null; then
  echo "Error: uv is not installed"
  echo "Install it with: brew install uv"
  exit 1
fi

LITELLM_SOURCE='litellm[proxy]'
if [[ "$USE_NIGHTLY" == true ]]; then
  LITELLM_SOURCE='litellm[proxy] @ git+https://github.com/BerriAI/litellm.git'
fi

echo "Starting litellm proxy on port $PORT..."

# Pin to Python 3.13 because uvloop doesn't support Python 3.14+
uvx --python 3.13 --from "$LITELLM_SOURCE" litellm --config "$CONFIG_FILE" --port $PORT
